rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens NEVER contain custom claims in this env unless set via functions
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() <= 50 &&
               data.photoURL is string && data.photoURL.size() <= 500 &&
               data.balance is number && data.balance >= 0 &&
               data.id == request.auth.uid;
      }

      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().balance == 0; // New users start at 0
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Only allow updating display info, not balance via client
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      ) || isAdmin();
    }

    // Author Rules (Expert profiles)
    match /authors/{authorId} {
      allow read: if true; // Public profiles
      allow write: if isAdmin(); // Only admins manage authors for now
    }

    // Prediction Rules
    match /predictions/{predictionId} {
      allow get, list: if true;
      
      function isValidPrediction(data) {
        return data.authorId is string && isValidId(data.authorId) &&
               data.title is string && data.title.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               data.createdAt == request.time;
      }

      allow create: if isAdmin() && isValidPrediction(incoming());
      allow update: if isAdmin() && isValidPrediction(incoming());
      allow delete: if isAdmin();

      // Protected Content Subcollection
      match /content/details {
        allow get: if isSignedIn() && (
          get(/databases/$(database)/documents/predictions/$(predictionId)).data.isFree == true ||
          exists(/databases/$(database)/documents/orders/$(request.auth.uid + "_" + predictionId)) ||
          isAdmin()
        );
      }
    }

    // Order Rules
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(incoming().userId) || isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      function isValidOrder(data) {
        return data.userId == request.auth.uid &&
               data.predictionId is string && isValidId(data.predictionId) &&
               data.amount is number && data.amount >= 0 &&
               data.createdAt == request.time;
      }

      // Orders are created when a user unlocks a prediction.
      allow create: if isSignedIn() && isValidOrder(incoming()) && 
                    orderId == request.auth.uid + "_" + incoming().predictionId;
    }
  }
}
